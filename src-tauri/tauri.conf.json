{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LifeOss",
  "version": "0.1.0",
  "identifier": "app.lifeoss.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LifeOss",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700
      }
    ],
    "security": { "csp": null }
  },
  "bundle": { "active": false }
}
